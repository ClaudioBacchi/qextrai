{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qExtrai",
  "version": "0.1.0",
  "identifier": "it.queen.qextrai",
  "mainBinaryName": "qExtrai",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "qExtrai",
        "label": "main",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "center": true,
        "maximized": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
